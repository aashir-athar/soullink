# Soullink Backend — Environment Variables
# Copy this file to .env and fill in your values
# Updated: 2026-04-17

# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:8081,exp://

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/soullink?retryWrites=true&w=majority

# Clerk Authentication (@clerk/express 2.x)
# Get these from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----
YOUR_CLERK_JWT_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"

# Cloudinary Media Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
