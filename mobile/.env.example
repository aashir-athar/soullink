# Soullink Expo App — Environment Variables
# Copy to .env and fill in values

# Clerk publishable key — https://dashboard.clerk.com/last-active?path=api-keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Soullink backend API base URL (Express + Socket.io)
EXPO_PUBLIC_API_URL=https://api.soullink.app
EXPO_PUBLIC_SOCKET_URL=https://api.soullink.app

# For local development on physical device, use your computer's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.10:3000
